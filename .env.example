# ── Aether Environment Variables ──
# Copy this file to .env.local and fill in the values

# Supabase (required for auth & data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Database (Prisma — only used for local dev with SQLite)
# On Vercel, this is not needed as the app uses Supabase for data
DATABASE_URL=file:./dev.db

# AI SDK (optional — used for AI features like tagging, search, transcription)
# If not set, AI features will be disabled gracefully
ZAI_API_KEY=your-zai-api-key-here

# Hugging Face API Token (optional — used for semantic search embeddings)
# Get a free token at https://huggingface.co/settings/tokens
# If not set, semantic search will fall back to keyword-based search
HF_API_TOKEN=your-hf-api-token-here
